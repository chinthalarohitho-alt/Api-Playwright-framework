<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Set root level to ERROR to suppress INFO and DEBUG logs -->
    <root level="ERROR">
        <appender-ref ref="STDOUT" />
    </root>

    <!-- Explicitly set known noisy loggers to ERROR -->
    <logger name="com.api.framework" level="ERROR" />
    <logger name="com.jayway.jsonpath" level="ERROR" />
    <logger name="org.testng" level="ERROR" />
</configuration>
